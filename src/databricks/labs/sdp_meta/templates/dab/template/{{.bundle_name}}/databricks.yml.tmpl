# Declarative Automation Bundle for the sdp-meta pipeline `{{.bundle_name}}`.
# Generated by `databricks labs sdp-meta bundle init`.
# See https://docs.databricks.com/aws/en/dev-tools/bundles/ for bundle docs.
bundle:
  name: {{.bundle_name}}

include:
  - resources/*.yml

sync:
  exclude:
    - .gitignore
    - .DS_Store
    - .vscode
    - .venv/

targets:
  dev:
    mode: development
    default: true
    # Uncomment and set to pin this target to a specific workspace:
    # workspace:
    #   host: https://<your-workspace>.cloud.databricks.com
    variables:
      # Development runs are mutable / non-photon by default; override as needed.
      development_enabled: true

  prod:
    mode: production
    # workspace:
    #   host: https://<your-workspace>.cloud.databricks.com
    #   root_path: /Workspace/Shared/${bundle.name}/${bundle.target}
    permissions:
      - group_name: users
        level: CAN_VIEW
    # Recommended for CI/CD: run prod jobs/pipelines under a service principal so
    # the bundle is decoupled from any one user account. Leave commented out for
    # ad-hoc/manual prod deploys (the deploying user is used as run_as in that
    # case). When you uncomment, replace the placeholder with the application_id
    # of a workspace-admin-granted service principal; `bundle-validate` will
    # flag the placeholder until you do.
    # run_as:
    #   service_principal_name: <your-prod-service-principal-application-id>
    variables:
      development_enabled: false
