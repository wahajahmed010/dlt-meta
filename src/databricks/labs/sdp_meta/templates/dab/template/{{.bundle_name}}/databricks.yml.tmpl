# Databricks Asset Bundle for the sdp-meta pipeline `{{.bundle_name}}`.
# Generated by `databricks labs sdp-meta bundle init`.
# See https://docs.databricks.com/dev-tools/bundles/ for bundle docs.
bundle:
  name: {{.bundle_name}}

include:
  - resources/*.yml

sync:
  exclude:
    - .gitignore
    - .DS_Store
    - .vscode
    - .venv/

targets:
  dev:
    mode: development
    default: true
    # Uncomment and set to pin this target to a specific workspace:
    # workspace:
    #   host: https://<your-workspace>.cloud.databricks.com
    variables:
      # Development runs are mutable / non-photon by default; override as needed.
      development_enabled: true

  prod:
    mode: production
    # workspace:
    #   host: https://<your-workspace>.cloud.databricks.com
    #   root_path: /Workspace/Shared/${bundle.name}/${bundle.target}
    permissions:
      - group_name: users
        level: CAN_VIEW
    variables:
      development_enabled: false
